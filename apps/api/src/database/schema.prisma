generator client {
  provider = "prisma-client-js"
  output   = "../src/database"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id
  name          String
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]
  members  WorkspaceMember[]

  @@unique([email])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

/**
 * Application Tables
 */

model Workspace {
  id        String   @id
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members                WorkspaceMember[]
  tickets                Ticket[]
  ticketLists            TicketList[]
  ticketAttachments      TicketAttachment[]
  ticketComments         TicketComment[]
  ticketLabels           TicketLabel[]
  workspaceTicketLabels  WorkspaceTicketLabel[]
  workspaceMemberInvites WorkspaceMemberInvite[]
}

model WorkspaceMember {
  id               String   @id
  isWorkspaceOwner Boolean  @default(false)
  workspaceId      String
  userId           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedTickets Ticket[]  @relation("Assignee")
  reportedTickets Ticket[]  @relation("Reporter")
  user            User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model WorkspaceMemberInvite {
  id          String   @id
  email       String
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([email])
}

model WorkspaceTicketLabel {
  id          String   @id
  name        String
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ticketLabels TicketLabel[]

  @@index([workspaceId])
}

model TicketList {
  id          String   @id
  name        String
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tickets   Ticket[]

  @@index([workspaceId])
}

model Ticket {
  id           String   @id
  title        String
  description  String
  workspaceId  String
  ticketListId String
  assigneeId   String?
  reporterId   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ticketList  TicketList         @relation(fields: [ticketListId], references: [id], onDelete: Cascade)
  assignee    WorkspaceMember?   @relation("Assignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  reporter    WorkspaceMember    @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  attachments TicketAttachment[]
  comments    TicketComment[]
  labels      TicketLabel[]

  @@index([workspaceId])
  @@index([ticketListId])
  @@index([assigneeId])
  @@index([reporterId])
}

model TicketAttachment {
  id          String   @id
  ticketId    String
  workspaceId String
  key         String
  name        String
  size        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ticket    Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model TicketComment {
  id          String   @id
  ticketId    String
  workspaceId String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ticket    Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model TicketLabel {
  id          String   @id
  ticketId    String
  workspaceId String
  labelId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ticket    Ticket               @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  workspace Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  label     WorkspaceTicketLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, ticketId, labelId])
  @@index([ticketId])
  @@index([workspaceId])
}
