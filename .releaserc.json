{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "pnpm release:version <%= nextRelease.version %>",
        "publishCmd": "pnpm release:publish"
      }
    ],
    "@semantic-release/github"
  ]
}
